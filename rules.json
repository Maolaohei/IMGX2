    "replace": "s=2048"
  },
  {
    "name": "SoundCloud",
    "hosts": "sndcdn\\.com",
    "match": "-(?:large|t\\d+x\\d+|crop)\\.(jpe?g|png)",
    "replace": "-original.$1"
  },
  {
    "name": "Medium",
    "hosts": "miro\\.medium\\.com",
