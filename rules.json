    "hosts": "avatars\\.akamai\\.steamstatic\\.com|steamcdn-a\\.akamaihd\\.net",
    "match": "_(?:medium|icon)(\\.(?:jpe?g|png|webp))",
    "replace": "_full$1"
  },
  {
    "name": "Discord (强化参数)",
    "hosts": "cdn\\.discordapp\\.com|media\\.discordapp\\.net",
    "match": "\\?size=\\d+",
    "replace": "?size=4096"
  },
  {
    "name": "YouTube Cover (视频封面全尺寸)",
    "hosts": "ytimg\\.com",
