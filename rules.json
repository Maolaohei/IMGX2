  },
  {
    "name": "115 Cloud (115网盘头像)",
    "hosts": "115\\.com",
    "match": "(avatars\\.115\\.com\\/.+_)\\w+(\\.(?:jpe?g|png|webp))",
    "replace": "$1l$2"
  },
  {
    "name": "Aliyun OSS / Tencent COS / Qiniu (全网主流CDN裁切参数强力剥离)",
    "hosts": "aliyuncs\\.com|myqcloud\\.com|.*",
    "match": "([?&@!])(?:x-oss-process=image|imageMogr2|imageView2).*",
    "replace": ""
  },
  {
    "name": "Common Strip Params (批量清理单纯靠问号传参的网站)",
    "hosts": "target\\.scene7\\.com|walmartimages\\.com|unsplash\\.com|images\\.pexels\\.com|istockphoto\\.com|ykimg\\.com|avatars\\.githubusercontent\\.com|steamcommunity\\.com|steampowered\\.com|music\\.163\\.com|nga\\.178\\.com",
    "match": "\\?.*$",
    "replace": ""
  },
  {
    "name": "Generic Size Suffix (全网通用后缀清理如 _400x400.jpg)",
    "hosts": ".*",
    "match": "[_-](\\d{2,4})x(\\d{2,4})(\\.(?:jpe?g|png|webp|gif)(?:\\?.*)?)$",
    "replace": "$3"
  },
  {
    "name": "Thumb to Large Path (全网通用路径清理)",
    "hosts": ".*",
    "match": "\\/(thumb(?:nail)?s?|small|mw\\d+)\\/",
    "replace": "/large/"
  }
]