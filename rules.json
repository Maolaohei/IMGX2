  {
    "name": "Wikipedia / Wikimedia (剥离维基百科缩略图约束)",
    "hosts": "wikimedia\\.org|wikipedia\\.org",
    "match": "\\/thumb\\/(.+?\\/[^/]+)\\.\\d+px-[^/]+$",
    "replace": "/$1"
  },
  {
    "name": "Google Play / Books (Google服务大图)",
    "hosts": "googleusercontent\\.com|books\\.google\\.com",
    "match": "=(?:s\\d+|w\\d+|h\\d+).*",
    "replace": "=s0"
  },
  {
    "name": "Gravatar (全球公认头像库)",
    "hosts": "gravatar\\.com",
