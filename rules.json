[
  {
    "name": "Pixiv (Artwork Original)",
    "hosts": "pximg\\.net",
    "match": "(pximg\\.net)\\/(?:c\\/[^/]+\\/)?(?:img-master|custom-thumb)(\\/img\\/.+?)(_p\\d+)?_(?:master|square|custom)[^.]*(\\.[a-zA-Z]+)",
    "replace": "$1/img-original$2$3$4"
  },
  {
    "name": "Pixiv (Strip Crop Fallback / img-master)",
    "hosts": "pximg\\.net",
    "match": "(pximg\\.net)\\/c!?\\/[^/]+(\\/.+)",
    "replace": "$1$2"
  },
  {
    "name": "Pixiv (User Profile)",
    "hosts": "pximg\\.net",
    "match": "(pximg\\.net\\/user-profile\\/.+?)_\\d+(\\.[a-zA-Z]+)",
    "replace": "$1$2"
  },
  {
    "name": "Pixiv (Thumb Directory)",
    "hosts": "pximg\\.net",
    "match": "(pximg\\.net\\/.*?_thumb\\/.+?)_\\w+(\\.[a-zA-Z]+)",
    "replace": "$1$2"
  },
  {
    "name": "Pixiv (Uploads)",
    "hosts": "pximg\\.net",
    "match": "(pximg\\.net)\\/.*?(\\/uploads\\/.+?\\/)(?:.+_)?(\\d+\\.[a-zA-Z]+)",
    "replace": "$1$2$3"
  },
  {
    "name": "Pixiv (Fanbox / Post)",
    "hosts": "pixiv\\.net",
    "match": "(pixiv\\.net\\/images\\/post\\/\\d+)\\/w\\/\\d+(\\/.+)",
    "replace": "$1$2"
  },
  {
    "name": "Amazon / Apple Media (全局无损)",
    "hosts": "amazon\\.(com|co\\.[a-z]+|[a-z]{2})|ssl-images-amazon\\.com|media-amazon\\.com|store\\.storeimages\\.cdn-apple\\.com",
    "match": "(\\._[A-Z0-9_,]+_)\\.(jpe?g|png|gif|webp)",
    "replace": ".$2"
  },
  {
    "name": "JD (京东 - 大图剥离)",
    "hosts": "360buyimg\\.com",
    "match": "\\/([sn]\\d+|jfs|g\\d+)\\/.*?(?:s\\d+x\\d+_)?(.+\\.(?:jpe?g|png|webp))",
    "replace": "/n0/$2"
  },
  {
    "name": "Taobao / Tmall / 1688 / Ali (阿里系电商)",
    "hosts": "(?:alicdn|taobao|tmall|1688|aliexpress|liangxinyao|alipay|alimama|vvic|wsy)\\.(?:com|[a-z]{2})",
    "match": "([_.]\\d+x\\d+[a-zA-Z0-9_]*|\\.search|\\.summ)(\\.(?:jpe?g|gif|png|webp|bmp|svg)(?:\\?.*)?)",
    "replace": "$2"
  },
  {
    "name": "Suning (苏宁易购)",
    "hosts": "suning\\.com",
    "match": "((?:image|imgservice)\\d*\\.suning\\.cn\\/.+?)\\d+([wh]_|x)\\d+(.*)",
    "replace": "${1}800${2}800$3"
  },
  {
    "name": "Dangdang (当当网)",
    "hosts": "ddimg\\.cn|dangdang\\.com",
    "match": "(.*\\.(?:ddimg\\.cn|dangdang\\.com)\\/[^_]+?)_[^oy]((?:_?\\w+)?\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "$1_o$2"
  },
  {
    "name": "Pinduoduo / Kuaishou (拼多多/快手)",
    "hosts": "pinduoduo\\.com|yangkeduo\\.com|kuaishou\\.com",
    "match": "(thumbnail\\/\\d+x\\d+\\/)",
    "replace": ""
  },
  {
    "name": "eBay (最大化 2000px)",
    "hosts": "ebayimg\\.com|ebaystatic\\.com",
    "match": "(i\\.ebayimg\\.com\\/.+\\/s-l|thumbs\\d+\\.ebaystatic\\.com\\/.+\\/l)\\d+(?:\\/p)?(\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "${1}2000$2"
  },
  {
    "name": "Etsy",
    "hosts": "etsystatic\\.com",
    "match": "(_)(\\d+x(?:\\d+|N))(.*?\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "_fullxfull$3"
  },
  {
    "name": "Bilibili (哔哩哔哩 - 封面与动态)",
    "hosts": "(hdslb\\.com|bilibili\\.com|bilivideo\\.com|biligame\\.com)",
    "match": "(.+\\.hdslb\\.com/.+?\\.(?:jpe?g|png|webp))(@.+)?(.*)",
    "replace": "$1"
  },
  {
    "name": "Zhihu (知乎 - 原图提取)",
    "hosts": "(zhimg\\.com|zhihu\\.com)",
    "match": "(\\/pic\\d+\\.zhimg\\.com\\/)(?:\\d+\\/)?(.+)_(?:\\d+x\\d+|xs|sm|md|hd|l|b|q|xl)(\\.(?:jpe?g|gif|png|webp)(?:\\?.*)?)",
    "replace": "$1$2_r$3"
  },
  {
    "name": "Weibo (微博正文图)",
    "hosts": "(sinaimg\\.cn|weibo\\.com)",
    "match": "(\\/)(small|bmiddle|thumbnail|mw\\d+|orj\\d+|sq\\d+|wap\\d+|crop\\.[^/]+|square)(\\/\\w+\\.(?:jpe?g|gif|png|webp)(?:\\?.*)?)",
    "replace": "$1large$3"
  },
  {
    "name": "Weibo Avatar (微博头像)",
    "hosts": "sinaimg\\.cn",
    "match": "(\\/)(180|50|30|crop\\.[^/]+)(\\/\\w)",
    "replace": "$1original$3"
  },
  {
    "name": "Twitter / X (Timeline)",
    "hosts": "twimg\\.com",
    "match": "(\\w+\\.twimg\\.com\\/media\\/.+?)(?:\\.(?:jpe?g|png|webp):\\w+)?(.+[?&]name=)[^&]+(.*)",
    "replace": "$1$2orig$3"
  },
  {
    "name": "Twitter / X (Profile/Banner)",
    "hosts": "twimg\\.com",
    "match": "(\\w+\\.twimg\\.com\\/(?:(?:[^/]+\\/)?default_)?profile_images\\/.+)_\\w+(?=\\.(?:jpe?g|png|webp))(\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "$1$2"
  },
  {
    "name": "Douban (豆瓣 - 影视/书影音/头像)",
    "hosts": "doubanio\\.com|douban\\.com",
    "match": "(img\\d+\\.doubanio\\.com\\/view\\/\\w+\\/).*(\\/public\\/.+\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "$1l$2"
  },
  {
    "name": "Reddit (Preview / Thumbnails)",
    "hosts": "redd\\.it|reddit\\.com",
    "match": "(?:preview|i)(\\.redd\\.it\\/.+\\.(?:jpe?g|png|webp)).*",
    "replace": "i$1"
  },
  {
    "name": "ArtStation (插画与模型库)",
    "hosts": "artstation\\.com",
    "match": "(cdn\\w?\\.artstation\\.com\\/.+?\\/)(?:\\d{14}\\/)?(?:medium|small|\\w+_square|thumbnail|micro)(\\/.+\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "$1large$2"
  },
  {
    "name": "DeviantArt",
    "hosts": "deviantart\\.net|deviantart\\.com",
    "match": "\\/f\\/([\\w/]+?)\\/[^/]+_(?:150|200|300|400)(\\.[a-z]+)",
    "replace": "/f/$1/original$2"
  },
  {
    "name": "Tumblr",
    "hosts": "tumblr\\.com",
    "match": "_(75sq|100|250|400|500|540|640)\\.(jpe?g|png|gif)",
    "replace": "_1280.$2"
  },
  {
    "name": "Pinterest",
    "hosts": "pinimg\\.com",
    "match": "(\\/\\/i\\.pinimg\\.com\\/)(?:\\d+x(?:\\d+(?:_\\w+)?)?)(\\/.+\\.(?:jpe?g|png|webp)(?:\\?.*)?)",
    "replace": "${1}originals$2"
  },
  {
    "name": "Imgur (剔除尺寸后缀)",
    "hosts": "imgur\\.com",
    "match": "(i\\.imgur\\.com\\/\\w{7})[bstml](\\.(?:jpe?g|png|gif)(?:\\?.*)?)",
    "replace": "$1$2"
  },
  {
    "name": "Flickr (b尺寸拉满)",
    "hosts": "staticflickr\\.com|static\\.flickr\\.com",
    "match": "(_[msznqcot])(\\.(?:jpe?g|png)(?:\\?.*)?)",
    "replace": "_b$2"
  },
  {
    "name": "Wallhaven (缩略图转大图)",
    "hosts": "wallhaven\\.cc",
    "match": "\\/th\\/",
    "replace": "/full/"
  },
  {
    "name": "500px",
    "hosts": "drscdn\\.500px\\.org|marketplace\\.500px\\.com",
    "match": "\\/w%3D\\d+",
    "replace": "/w%3D2048"
  },
  {
    "name": "Dribbble",
    "hosts": "cdn\\.dribbble\\.com",
    "match": "\\/\\d+x\\d+(\\/.+)",
    "replace": "$1"
  },
  {
    "name": "Behance (源文件提取)",
    "hosts": "mir-s3-cdn-cf\\.behance\\.net",
    "match": "\\/project_modules\\/(?:disp|max_\\d+|2800_opt_\\d+)\\/",
    "replace": "/project_modules/source/"
  },
  {
    "name": "Instagram / Facebook (剥离路径限制)",
    "hosts": "cdninstagram\\.com|fbcdn\\.net",
    "match": "\\/(?:s\\d+x\\d+\\/|p\\d+x\\d+\\/|c\\d+\\.\\d+\\.\\d+\\.\\d+\\/|vp\\/)+",
    "replace": "/"
  },
  {
